# ForgeLab Environment Variables
# Copy this file to .env.local and fill in your keys

# Google Gemini API Key (for research, guide generation, vendor search, image generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Zoo.dev API Token (for 3D model generation via Text-to-CAD)
# Get yours at: https://zoo.dev/account/api-tokens
ZOO_API_KEY=

# DraftAid API Key (for 2D blueprint generation — optional, mocked if missing)
# Contact: https://draftaid.io for API access
DRAFTAID_API_KEY=

# Google Cloud Project (for Vertex AI — Veo 3 video generation)
# Set up at: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
